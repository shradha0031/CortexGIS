{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Spatial Workflow",
  "type": "object",
  "properties": {
    "id": {"type": "string"},
    "description": {"type": "string"},
    "inputs": {"type": "object"},
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "tool": {
            "type": "string",
            "description": "Name of a registered tool (see gis_functions_schema.json)"
          },
          "op": {"type": "string", "description": "Specific operation or method in the tool"},
          "params": {"type": "object", "description": "Parameters passed to the tool"},
          "inputs": {"type": ["array","null"], "description": "References to outputs from previous steps"},
          "outputs": {"type": ["array","null"], "description": "List of artifacts produced"}
        },
        "required": ["id","tool"]
      }
    },
    "outputs": {"type": "array"},
    "cot": {"type": "array", "items": {"type": "string"}, "description": "Chain-of-thought reasoning records"}
  },
  "required": ["id","steps"]
}
